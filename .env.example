# Bosch HPA Bot — environment (Option B: hardened, Bearer-only, no Supabase service key)
# Copy to .env and fill in real values. NEVER commit a real .env (it is gitignored).

# Shared Bearer secret between this bot and the auraos app. Used to:
#   - authenticate the inbound POST /api/run-advisor (constant-time compare, fail-closed)
#   - authenticate the outbound result callback + PDF upload to auraos
# Must be IDENTICAL to the auraos Vercel server env BOSCH_BOT_WEBHOOK_SECRET.
BOSCH_BOT_WEBHOOK_SECRET=

# Full URL of the auraos result-callback endpoint. The bot POSTs the advisor result here.
# Example: https://staging.example.com/api/internal/bosch-planer-callback
AURAOS_CALLBACK_URL=

# Full URL of the auraos PDF-upload endpoint. OPTIONAL — if unset it is derived from
# AURAOS_CALLBACK_URL's origin + /api/internal/bosch-planer-pdf.
# Example: https://staging.example.com/api/internal/bosch-planer-pdf
AURAOS_PDF_URL=

# Port (optional, default 3000).
PORT=3000
